# Visions of Aetherius API
PORT=3100
HOST=0.0.0.0
PUBLIC_URL=http://178.156.158.116:3100
DATA_DIR=./data
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_TTL_SEC=3600
REFRESH_TOKEN_TTL_SEC=2592000
SESSION_TTL_SEC=900

# Discord OAuth (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Comma-separated Discord user IDs allowed to post news
ADMIN_DISCORD_IDS=

# Community gate (double security): must be in this Discord server to login/play
# Right-click server (Developer Mode on) → Copy Server ID
DISCORD_GUILD_ID=
# Optional invite shown in error messages (https://discord.gg/...)
DISCORD_INVITE_URL=
# Optional bot for re-check on every Play (invite bot to the server; enable Server Members Intent)
DISCORD_BOT_TOKEN=
# Default: on when DISCORD_GUILD_ID is set. Set false only for emergency bypass.
# REQUIRE_DISCORD_GUILD=true

# Game server
GAME_SERVER_IP=178.156.158.116
GAME_SERVER_PORT=10000
GAME_SERVER_NAME=Visions of Aetherius
# Host:port used in SkyMP master lookup path (must match server login address)
GAME_SERVER_ADDR=178.156.158.116:10000

# Optional maintenance banner
MAINTENANCE=false
STATUS_MESSAGE=

# CDN base for client updates (optional until Phase 5)
CDN_BASE_URL=http://178.156.158.116:3100/cdn

# Nexus Mods API (register app with support@nexusmods.com — do not use personal keys in production)
# https://help.nexusmods.com/article/114-api-acceptable-use-policy
# OAuth guide: https://modding.wiki/en/api/oauth2-guide
NEXUS_API_KEY=
NEXUS_APP_NAME=VisionsOfAetheriusLauncher
# Future OAuth / SSO callback (local launcher helper port)
# NEXUS_OAUTH_CALLBACK=http://127.0.0.1:47821/auth/nexus/callback
