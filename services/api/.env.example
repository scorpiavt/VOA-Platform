# Visions of Aetherius API — production must satisfy docs/NEXUS_COMPLIANCE.md

PORT=3100
HOST=0.0.0.0

# §3 HTTPS: non-local PUBLIC_URL MUST be https:// (process refuses http:// for public hosts)
PUBLIC_URL=https://api.example.com
DATA_DIR=./data

# §5 Secrets: required in production; NO placeholders; min 24 characters each
JWT_SECRET=
GAME_SERVER_SECRET=
ACCESS_TOKEN_TTL_SEC=3600
REFRESH_TOKEN_TTL_SEC=2592000
SESSION_TTL_SEC=900

# Discord OAuth (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
ADMIN_DISCORD_IDS=
DISCORD_GUILD_ID=
DISCORD_INVITE_URL=
DISCORD_BOT_TOKEN=

# Game server (address for clients; TLS is for HTTP(S) API, not game UDP)
GAME_SERVER_IP=
GAME_SERVER_PORT=10000
GAME_SERVER_NAME=Visions of Aetherius
GAME_SERVER_ADDR=

MAINTENANCE=false
STATUS_MESSAGE=

# §3 HTTPS CDN base (or leave empty to use PUBLIC_URL/cdn)
CDN_BASE_URL=

# Internal localhost status sidecar is OK as http://127.0.0.1
GAME_STATUS_URL=http://127.0.0.1:3099/status

# Nexus: NO personal API key. Player downloads = launcher user OAuth only.
# Do NOT set NEXUS_API_KEY / NEXUS_PERSONAL_KEY / NEXUSMODS_API_KEY —
# the API process refuses to start if any of those are set (docs/NEXUS_COMPLIANCE.md §1–§2).
NEXUS_APP_NAME=VisionsOfAetheriusLauncher

# §4 Optional: public key also embedded in launcher; private key offline only
# VOA_UPDATE_PUBLIC_KEY=

# Proximity voice (Keizaal-style in-game CEF + LiveKit). All three required to enable.
# Generate keys: docker run --rm livekit/livekit-server generate-keys
# LIVEKIT_URL=wss://voice.visionsofaetherius.com
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# LIVEKIT_ROOM=voa-main
# LIVEKIT_TOKEN_TTL_SEC=7200
