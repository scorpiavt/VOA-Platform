{
  "name": "voa-launcher",
  "version": "0.2.16",
  "private": true,
  "description": "Visions of Aetherius launcher",
  "author": "Visions of Aetherius",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.node.json --noEmit && vite build",
    "build:electron-types": "tsc -p tsconfig.electron.json --noEmit",
    "preview": "vite preview",
    "start:electron": "electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --win portable nsis",
    "dist:public": "npm run build && electron-builder --win portable nsis",
    "dist:portable": "npm run build && electron-builder --win portable",
    "dist:nsis": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "@voa/shared": "0.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8",
    "rcedit": "^5.0.2",
    "resedit": "^1.7.2",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.visionsofaetherius.launcher",
    "productName": "VisionsOfAetherius",
    "copyright": "Visions of Aetherius",
    "electronVersion": "34.3.0",
    "afterPack": "./afterPack.js",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "icon": "build/icon.ico",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "public/hero-art.png",
      "build/icon.ico",
      "build/icon.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "../../client-dist/skymp5-client.js",
        "to": "client/skymp5-client.js"
      },
      {
        "from": "../../client-dist/Interface/Controls/PC/controlmap.txt",
        "to": "client/Interface/Controls/PC/controlmap.txt"
      },
      {
        "from": "public/music/launcher-theme.mp3",
        "to": "music/launcher-theme.mp3"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "executableName": "VisionsOfAetherius",
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        },
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "portable": {
      "artifactName": "VisionsOfAetherius-${version}-portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Visions of Aetherius",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "artifactName": "VisionsOfAetherius-Setup-${version}.${ext}",
      "uninstallDisplayName": "Visions of Aetherius Launcher"
    },
    "asar": true,
    "protocols": [
      {
        "name": "Visions of Aetherius",
        "schemes": [
          "voa"
        ]
      }
    ]
  }
}
